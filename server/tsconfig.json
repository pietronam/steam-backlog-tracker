{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "types": ["node"],
        "strict": true,

        "rootDir": "./src",
        "outDir": "./dist",

        "esModuleInterop": true,

        "skipLibCheck": true
    },

    "include": ["src"]
}